---
interface Post {
  slug: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    tags?: string[];
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatarData(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

{posts.length > 0 && (
  <section class="secao blog-preview" id="blog">
    <div class="container">
      <div class="blog-preview__cabecalho">
        <h2>Do blog</h2>
        <p>Conteúdo sobre saúde mental infantojuvenil, dicas para pais e muito mais.</p>
        <a href="/blog" class="blog-preview__ver-todos">Ver todos os artigos →</a>
      </div>

      <ul class="blog-preview__grid">
        {posts.map(post => (
          <li class="post-card">
            <a href={`/blog/${post.slug}`} class="post-card__link" aria-label={`Ler: ${post.data.title}`}>
              <div class="post-card__decoracao" aria-hidden="true">
                <svg viewBox="0 0 200 120" xmlns="http://www.w3.org/2000/svg" width="200" height="120">
                  <rect width="200" height="120" fill="var(--cor-verde-claro)" opacity="0.4" rx="12"/>
                  <circle cx="40" cy="60" r="25" fill="var(--cor-verde-escuro)" opacity="0.15"/>
                  <circle cx="160" cy="40" r="18" fill="var(--cor-rosa)" opacity="0.2"/>
                  <rect x="60" y="30" width="100" height="8" rx="4" fill="var(--cor-verde-escuro)" opacity="0.15"/>
                  <rect x="60" y="50" width="80" height="6" rx="3" fill="var(--cor-verde-escuro)" opacity="0.1"/>
                  <rect x="60" y="65" width="90" height="6" rx="3" fill="var(--cor-verde-escuro)" opacity="0.1"/>
                </svg>
              </div>
              <div class="post-card__conteudo">
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="post-card__tag">{post.data.tags[0]}</span>
                )}
                <h3 class="post-card__titulo">{post.data.title}</h3>
                <p class="post-card__descricao">{post.data.description}</p>
                <time class="post-card__data" datetime={post.data.pubDate.toISOString()}>
                  {formatarData(post.data.pubDate)}
                </time>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .blog-preview {
    background-color: var(--cor-fundo);
  }

  .blog-preview__cabecalho {
    text-align: center;
    margin-bottom: var(--espacamento-lg);
  }

  .blog-preview__cabecalho p {
    margin-inline: auto;
    font-size: 1.05rem;
    color: var(--cor-texto);
    opacity: 0.8;
    margin-top: 0.5rem;
  }

  .blog-preview__ver-todos {
    display: inline-block;
    margin-top: var(--espacamento-sm);
    color: var(--cor-verde-escuro);
    font-weight: 600;
    font-size: 0.95rem;
    transition: gap var(--transicao);
  }

  .blog-preview__ver-todos:hover {
    text-decoration: underline;
  }

  .blog-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--espacamento-md);
  }

  .post-card {
    background-color: #fff;
    border-radius: var(--raio-lg);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(78, 111, 76, 0.08);
    transition: transform var(--transicao), box-shadow var(--transicao);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(78, 111, 76, 0.14);
  }

  .post-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  .post-card__decoracao svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-card__conteudo {
    padding: var(--espacamento-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .post-card__tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cor-verde-escuro);
    background-color: var(--cor-verde-claro);
    padding: 0.2rem 0.6rem;
    border-radius: var(--raio-full);
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-card__titulo {
    font-size: 1.05rem;
    color: var(--cor-verde-escuro);
    line-height: 1.35;
  }

  .post-card__descricao {
    font-size: 0.9rem;
    color: var(--cor-texto);
    opacity: 0.75;
    line-height: 1.65;
    max-width: none;
    flex: 1;
  }

  .post-card__data {
    font-size: 0.8rem;
    color: var(--cor-texto);
    opacity: 0.5;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .blog-preview__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
  }
</style>
